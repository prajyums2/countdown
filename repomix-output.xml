<file path="src/components/MapView.tsx">
"use client";

import { useId, useMemo } from "react";
import { motion } from "framer-motion";
import type { Station } from "@/lib/types";
import { useNow } from "@/lib/dev-time";

function CompassRose() {
  return (
    <svg width="36" height="36" viewBox="0 0 36 36" className="opacity-30">
      <circle cx="18" cy="18" r="16" fill="none" stroke="#F9A8D4" strokeWidth="0.5" />
      <polygon points="18,4 21,16 18,14 15,16" fill="#F9A8D4" />
      <polygon points="18,32 21,20 18,22 15,20" fill="#FBCFE8" />
      <polygon points="4,18 16,21 14,18 16,15" fill="#FBCFE8" />
      <polygon points="32,18 20,21 22,18 20,15" fill="#F9A8D4" />
      <circle cx="18" cy="18" r="2" fill="#F472B6" />
    </svg>
  );
}

function PinBadge({
  station,
  index,
  visited,
}: {
  station: Station;
  index: number;
  visited: boolean;
}) {
  const rotations = [-2, 3, -1, 4, -3, 2, -4, 1, -2];
  const rotate = rotations[index % rotations.length];

  return (
    <motion.div
      className={`rounded-xl p-3 shadow-lg shadow-rose-900/5 border flex-shrink-0 ${
        visited
          ? "bg-white/95 border-rose-50"
          : "bg-white/60 border-rose-100/50"
      }`}
      style={{ transform: `rotate(${rotate}deg)` }}
      initial={{ opacity: 0, y: 20 }}
      whileInView={{ opacity: 1, y: 0 }}
      viewport={{ once: true }}
      transition={{ type: "spring", stiffness: 100, damping: 16, delay: index * 0.08 }}
      whileHover={{ scale: 1.05, rotate: 0 }}
    >
      <div className="flex items-start gap-2.5">
        <div className={`flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-lg shadow-sm border ${
          visited
            ? "bg-gradient-to-br from-rose-50 to-pink-50 border-rose-100"
            : "bg-slate-50 border-slate-100"
        }`}>
          {station.emoji}
        </div>
        <div className="min-w-0 flex-1">
          <p className={`text-xs font-semibold truncate ${
            visited ? "text-slate-700" : "text-slate-400"
          }`}>
            {station.name}
          </p>
          <p className={`text-[0.55rem] font-caveat ${
            visited ? "text-rose-400" : "text-slate-300"
          }`}>
            {new Date(station.dateTime).toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
            })}
          </p>
          {station.description && (
            <p className={`text-[0.55rem] mt-0.5 leading-tight line-clamp-2 font-caveat ${
              visited ? "text-slate-500" : "text-slate-300"
            }`}>
              {station.description}
            </p>
          )}
        </div>
        {visited && (
          <span className="text-[0.5rem] text-rose-300 mt-0.5">✓</span>
        )}
      </div>
    </motion.div>
  );
}

export default function MapView({ stations }: { stations: Station[] }) {
  const id = useId();
  const now = useNow();
  const sorted = useMemo(() => [...stations].sort((a, b) => a.orderIndex - b.orderIndex), [stations]);

  const visitedIndices = useMemo(
    () => sorted.map((s) => new Date(s.dateTime).getTime() <= now.getTime()),
    [sorted, now]
  );

  const visitedCount = visitedIndices.filter(Boolean).length;

  const svgWidth = 320;
  const svgHeight = Math.max(sorted.length * 90 + 40, 320);

  const points = useMemo(
    () =>
      sorted.map((_, i) => {
        const y = 30 + (i * (svgHeight - 60)) / Math.max(sorted.length - 1, 1);
        const xOff = i % 2 === 0 ? -25 : 25;
        return { x: svgWidth / 2 + xOff, y };
      }),
    [sorted.length]
  );

  const pathD = useMemo(() => points.map((p, i) => `${i === 0 ? "M" : "L"}${p.x},${p.y}`).join(" "), [points]);

  const visitedPathD = visitedCount > 0
    ? points.slice(0, visitedCount).map((p, i) => `${i === 0 ? "M" : "L"}${p.x},${p.y}`).join(" ")
    : "";

  return (
    <motion.section
      className="relative bg-gradient-to-b from-white/60 to-white/30 backdrop-blur-sm rounded-[2.5rem] p-6 md:p-8 border border-white/60 shadow-[0_8px_30px_-12px_rgba(244,114,182,0.2)]"
      initial={{ opacity: 0, y: 30 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ type: "spring", stiffness: 80, damping: 20 }}
    >
      <div className="absolute inset-0 bg-grid-lines opacity-40 rounded-[2.5rem] pointer-events-none" />

      <div className="relative z-10">
        <div className="text-center mb-6 space-y-1">
          <div className="flex items-center justify-center gap-3">
            <span className="h-px w-8 bg-gradient-to-r from-transparent to-rose-200" />
            <h2 className="text-xl font-caveat text-slate-600">Our Route</h2>
            <span className="h-px w-8 bg-gradient-to-l from-transparent to-rose-200" />
          </div>
          <p className="text-xs text-slate-400 font-caveat">
            Tracing the path of our journey together
          </p>
        </div>

        <div className="flex flex-col md:flex-row items-start gap-6">
          <div className="flex-shrink-0 w-full md:w-[320px] flex justify-center relative">
            <div className="absolute top-2 right-2 z-10">
              <CompassRose />
            </div>
            <svg
              width={svgWidth}
              height={svgHeight}
              viewBox={`0 0 ${svgWidth} ${svgHeight}`}
              className="overflow-visible"
            >
              <defs>
                <linearGradient id={`mg-${id}`} x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stopColor="#F9A8D4" />
                  <stop offset="50%" stopColor="#FBCFE8" />
                  <stop offset="100%" stopColor="#F9A8D4" />
                </linearGradient>
              </defs>

              <motion.path
                d={pathD}
                stroke={`url(#mg-${id})`}
                strokeWidth="3"
                strokeDasharray="8 6"
                fill="none"
                strokeLinecap="round"
                initial={{ pathLength: 0 }}
                animate={{ pathLength: 1 }}
                transition={{ duration: 2.5, ease: "easeInOut" }}
              />

              {visitedPathD && (
                <motion.path
                  d={visitedPathD}
                  stroke="#F472B6"
                  strokeWidth="3"
                  fill="none"
                  strokeLinecap="round"
                  initial={{ pathLength: 0 }}
                  animate={{ pathLength: 1 }}
                  transition={{ duration: 0.8, ease: "easeOut" }}
                />
              )}

              <motion.circle
                cx={points[0]?.x}
                cy={points[0]?.y}
                r="6"
                fill="#F472B6"
                initial={{ scale: 0 }}
                animate={{ scale: [1, 1.3, 1] }}
                transition={{ duration: 2, repeat: Infinity }}
              />

              {points.map((pt, i) => {
                const visited = visitedIndices[i];
                return (
                  <g key={sorted[i]?.id || i}>
                    <motion.circle
                      cx={pt.x}
                      cy={pt.y}
                      r="12"
                      fill={visited ? "#FDF2F8" : "white"}
                      stroke={visited ? "#F472B6" : "#FBCFE8"}
                      strokeWidth="2.5"
                      initial={{ scale: 0 }}
                      animate={{ scale: 1 }}
                      transition={{ delay: 0.1 * i, type: "spring", stiffness: 150, damping: 12 }}
                    />
                    <motion.text
                      x={pt.x}
                      y={pt.y + 0.5}
                      textAnchor="middle"
                      dominantBaseline="central"
                      fontSize="13"
                      fill={visited ? "#F472B6" : "#CBD5E1"}
                      initial={{ opacity: 0 }}
                      animate={{ opacity: 1 }}
                      transition={{ delay: 0.2 + 0.1 * i }}
                    >
                      {sorted[i]?.emoji || "●"}
                    </motion.text>
                    <motion.text
                      x={pt.x}
                      y={pt.y + 22}
                      textAnchor="middle"
                      fontSize="5"
                      fill={visited ? "#F472B6" : "#CBD5E1"}
                      fontWeight="bold"
                      initial={{ opacity: 0 }}
                      animate={{ opacity: 1 }}
                      transition={{ delay: 0.3 + 0.1 * i }}
                      className="font-caveat"
                    >
                      {i + 1}
                    </motion.text>
                  </g>
                );
              })}

              {visitedCount > 0 && visitedCount < sorted.length && (
                <motion.circle
                  cx={points[visitedCount - 1]?.x}
                  cy={points[visitedCount - 1]?.y}
                  r="18"
                  fill="none"
                  stroke="#F472B6"
                  strokeWidth="1"
                  strokeDasharray="3 4"
                  initial={{ scale: 0.8, opacity: 0 }}
                  animate={{ scale: 1.3, opacity: [0.4, 0] }}
                  transition={{ duration: 2, repeat: Infinity }}
                />
              )}
            </svg>
          </div>

          <div className="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-2.5 w-full">
            {sorted.map((station, i) => (
              <PinBadge key={station.id} station={station} index={i} visited={visitedIndices[i]} />
            ))}
          </div>
        </div>
      </div>
    </motion.section>
  );
}
</file>

