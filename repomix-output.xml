export default function CandleCake({
  onAllBlown,
}: {
  onAllBlown?: () => void;
}) {
  const [lit, setLit] = useState([true, true, true]);
  const [showMessage, setShowMessage] = useState(false);

  const totalCandles = 3;

  const handleBlow = (index: number) => {
    const next = [...lit];
    next[index] = false;
