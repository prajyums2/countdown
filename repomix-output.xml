"use client";

import { useEffect, useState, useId, useMemo } from "react";
import { motion } from "framer-motion";
import type { Station, StationProgress } from "@/lib/types";
import { getStationsProgress } from "@/utils/time";
import { useNow } from "@/lib/dev-time";

const TRACK_HEIGHT = 500;
const PADDING_Y = 50;
const TRACK_WIDTH = 140;

function TrainIcon() {
  return (
    <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
      <rect x="8" y="13" width="20" height="10" rx="5" fill="#FBCFE8" stroke="#F9A8D4" strokeWidth="0.8" />
      <rect x="5" y="17" width="5" height="6" rx="2.5" fill="#F9A8D4" />
      <circle cx="13" cy="26" r="3.5" fill="#F472B6" stroke="#FDF2F8" strokeWidth="1.5" />
      <circle cx="23" cy="26" r="3.5" fill="#F472B6" stroke="#FDF2F8" strokeWidth="1.5" />
      <rect x="11" y="7" width="15" height="7" rx="3.5" fill="#FDF2F8" stroke="#FBCFE8" strokeWidth="0.8" />
      <rect x="10" y="9" width="4" height="3" rx="1.5" fill="#FBCFE8" />
      <rect x="16" y="9" width="4" height="3" rx="1.5" fill="#FBCFE8" />
      <rect x="22" y="9" width="4" height="3" rx="1.5" fill="#FBCFE8" />
    </svg>
  );
}

function Badge({ children, icon }: { children: React.ReactNode; icon?: string }) {
  return (
    <div className="bg-white shadow-md border border-rose-100 text-rose-500 text-xs font-semibold rounded-full px-5 py-2 whitespace-nowrap flex items-center gap-1.5">
      {icon && <span>{icon}</span>}
      {children}
    </div>
  );
}

function TrackStar({ delay, x, y }: { delay: number; x: number; y: number }) {
  return (
    <motion.text
      x={x}
      y={y}
      textAnchor="middle"
      dominantBaseline="central"
      fontSize="7"
      fill="#FBCFE8"
      initial={{ opacity: 0, scale: 0 }}
      animate={{ opacity: [0, 1, 0], scale: [0, 1.2, 0] }}
      transition={{ duration: 3, delay, repeat: Infinity, ease: "easeInOut" }}
    >
      ✦
    </motion.text>
  );
}

function getPointOnPath(
  stations: Station[],
  progress: StationProgress
): { x: number; y: number } {
  const count = stations.length;
  if (count < 2) return { x: TRACK_WIDTH / 2, y: PADDING_Y };
  const usableHeight = TRACK_HEIGHT - PADDING_Y * 2;
  const segmentHeight = usableHeight / (count - 1);
  const rawIndex = progress.overallPercent / 100;
  const exactIndex = rawIndex * (count - 1);
  const baseY = PADDING_Y + exactIndex * segmentHeight;
  const xOffset = Math.sin((exactIndex / (count - 1)) * Math.PI * 2) * 30;
  return { x: TRACK_WIDTH / 2 + xOffset, y: baseY };
}

export default function StationsTrack({
  stations,
  onStationClick,
}: {
  stations: Station[];
  onStationClick: (station: Station) => void;
}) {
  const [mounted, setMounted] = useState(false);
  const [progress, setProgress] = useState<StationProgress>({
    overallPercent: 0,
    currentLegIndex: 0,
    totalLegs: 0,
    legPercent: 0,
    prevStation: null,
    nextStation: null,
  });
  const id = useId();
  const now = useNow();
  const sorted = useMemo(() => [...stations].sort((a, b) => a.orderIndex - b.orderIndex), [stations]);

  useEffect(() => setMounted(true), []);

  useEffect(() => {
    if (mounted && sorted.length) setProgress(getStationsProgress(sorted, now));
  }, [mounted, sorted, now]);

  const usableHeight = TRACK_HEIGHT - PADDING_Y * 2;
  const segmentHeight = sorted.length > 1 ? usableHeight / (sorted.length - 1) : 0;

  const trackPoints = useMemo(
    () =>
      sorted.map((_, i) => {
        const y = PADDING_Y + i * segmentHeight;
        const xOffset = Math.sin((i / (Math.max(sorted.length - 1, 1))) * Math.PI * 2) * 30;
        return { x: TRACK_WIDTH / 2 + xOffset, y };
      }),
    [sorted.length, segmentHeight]
  );

  const pathD = useMemo(
    () => trackPoints.map((p, i) => `${i === 0 ? "M" : "L"}${p.x},${p.y}`).join(" "),
    [trackPoints]
  );

  const stars = useMemo(
    () =>
      Array.from({ length: 12 }, (_, i) => ({
        key: i,
        delay: i * 0.4,
        x: 10 + Math.random() * (TRACK_WIDTH - 20),
        y: 10 + Math.random() * (TRACK_HEIGHT - 20),
      })),
    []
  );

  const trainPos = mounted && sorted.length > 1
    ? getPointOnPath(sorted, progress)
    : { x: TRACK_WIDTH / 2, y: PADDING_Y };

  return (
    <motion.section
      className="relative flex flex-col items-center py-16"
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      transition={{ duration: 0.6 }}
    >
      <div className="relative" style={{ width: TRACK_WIDTH, height: TRACK_HEIGHT }}>
        <motion.svg
          width={TRACK_WIDTH}
          height={TRACK_HEIGHT}
          viewBox={`0 0 ${TRACK_WIDTH} ${TRACK_HEIGHT}`}
          fill="none"
          className="absolute inset-0 overflow-visible"
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{ duration: 0.6 }}
        >
          <defs>
            <linearGradient id={`tg-${id}`} x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stopColor="#F9A8D4" />
              <stop offset="50%" stopColor="#FBCFE8" />
              <stop offset="100%" stopColor="#F9A8D4" />
            </linearGradient>
          </defs>

          <path d={pathD} stroke={`url(#tg-${id})`} strokeWidth="3" strokeDasharray="8 8" strokeLinecap="round" />

          {stars.map((s) => (
            <TrackStar key={s.key} delay={s.delay} x={s.x} y={s.y} />
          ))}

          {trackPoints.map((pt, i) => {
            const visited = i <= progress.currentLegIndex && progress.overallPercent < 100;
            return (
              <g key={sorted[i]?.id || i} onClick={() => onStationClick(sorted[i])} style={{ cursor: "pointer" }}>
                <motion.circle
                  cx={pt.x}
                  cy={pt.y}
                  r={visited ? 13 : 11}
                  fill={visited ? "#FDF2F8" : "white"}
                  stroke={visited ? "#F9A8D4" : "#FBCFE8"}
                  strokeWidth={visited ? 3 : 2}
                  initial={{ scale: 0 }}
                  animate={{ scale: 1 }}
                  transition={{ delay: i * 0.05, type: "spring", stiffness: 150, damping: 12 }}
                  whileHover={{ scale: 1.2 }}
                />
                {visited && (
                  <motion.circle
                    cx={pt.x}
                    cy={pt.y}
                    r={17}
                    fill="none"
                    stroke="#F9A8D4"
                    strokeWidth="1"
                    strokeDasharray="3 4"
                    initial={{ scale: 0.5, opacity: 0 }}
                    animate={{ scale: 1.2, opacity: [0.4, 0] }}
                    transition={{ duration: 2, repeat: Infinity }}
                  />
                )}
                <motion.text
                  x={pt.x}
                  y={pt.y + 0.5}
                  textAnchor="middle"
                  dominantBaseline="central"
                  fontSize="11"
                  fill={visited ? "#F472B6" : "#CBD5E1"}
                  initial={{ opacity: 0 }}
                  animate={{ opacity: 1 }}
                  transition={{ delay: 0.2 + i * 0.05 }}
                >
                  {sorted[i]?.emoji || "●"}
                </motion.text>
              </g>
            );
          })}

          {mounted && (
            <defs>
              <filter id={`glow-${id}`}>
                <feGaussianBlur stdDeviation="3" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>
          )}
        </motion.svg>

        {mounted && (
          <motion.div
            className="absolute z-10"
            style={{ left: trainPos.x - 18, top: 0 }}
            animate={{ top: trainPos.y - 18 }}
            transition={{ type: "spring", stiffness: 50, damping: 22 }}
          >
            <motion.div
              animate={{ y: [0, -5, 0] }}
              transition={{ duration: 2, repeat: Infinity, ease: "easeInOut" }}
              className="drop-shadow-lg"
            >
              <motion.div
                animate={{ opacity: [0.3, 0.6, 0.3] }}
                transition={{ duration: 1.5, repeat: Infinity }}
                className="absolute -inset-3 bg-rose-300/20 rounded-full blur-xl"
              />
              <TrainIcon />
            </motion.div>
          </motion.div>
        )}

        <div className="absolute -top-4 left-1/2 -translate-x-1/2">
          <Badge icon="🚉">Thrissur</Badge>
        </div>

        <div className="absolute -bottom-4 left-1/2 -translate-x-1/2">
          <Badge icon="🏁">Gurugram</Badge>
        </div>
      </div>

      {mounted && sorted.length > 1 && (
        <motion.div
          className="mt-10 flex flex-col items-center gap-3"
          initial={{ opacity: 0, y: 10 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.3 }}
        >
          <div className="w-56 bg-white/60 backdrop-blur-sm rounded-2xl p-1 shadow-sm border border-rose-50 overflow-hidden">
            <motion.div
              className="h-2 rounded-full bg-gradient-to-r from-rose-300 via-rose-400 to-pink-400"
              style={{ width: `${progress.overallPercent}%` }}
              animate={{ width: `${progress.overallPercent}%` }}
              transition={{ type: "spring", stiffness: 60, damping: 20 }}
            />
          </div>

          <div className="bg-white/50 backdrop-blur-sm border border-rose-50 rounded-2xl px-7 py-3 shadow-sm">
            <p className="text-sm text-slate-500">
              <span className="font-semibold text-rose-400">{progress.overallPercent}%</span> complete
            </p>
          </div>

          {progress.prevStation && progress.nextStation && (
            <div className="bg-white/40 backdrop-blur-sm border border-rose-50/50 rounded-xl px-4 py-2 shadow-sm">
              <p className="text-xs text-slate-400 font-caveat flex items-center gap-1.5">
                <span className="text-base">{progress.prevStation.emoji}</span>
                <span className="text-slate-500 truncate max-w-[80px]">{progress.prevStation.name}</span>
                <span className="text-rose-300 mx-0.5">→</span>
                <span className="text-base">{progress.nextStation.emoji}</span>
                <span className="text-slate-500 truncate max-w-[80px]">{progress.nextStation.name}</span>
                <span className="text-[0.55rem] text-rose-400 bg-rose-50 px-1.5 py-0.5 rounded-full ml-1">
