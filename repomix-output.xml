  const res = await fetch(API_BASE, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ action: "addStation", payload: station, pin }),
  });
  if (!res.ok) throw new Error("Failed to add station");
  return res.json();
}

