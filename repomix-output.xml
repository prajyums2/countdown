        animate={{ y: [0, -6, 0] }}
        transition={{ duration: 2.5, repeat: Infinity, ease: "easeInOut" }}
        className="relative drop-shadow-xl"
      >
        <motion.svg
          width="160"
          height="100"
          viewBox="0 0 160 100"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <defs>
            <linearGradient id="trainBody" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stopColor="#FDF2F8" />
              <stop offset="100%" stopColor="#FBCFE8" />
            </linearGradient>
          </defs>
          <rect x="34" y="38" width="92" height="34" rx="12" fill="url(#trainBody)" stroke="#F9A8D4" strokeWidth="1.5" />
          <rect x="26" y="48" width="14" height="20" rx="6" fill="#F9A8D4" />
          <circle cx="50" cy="78" r="8" fill="#F472B6" stroke="#FDF2F8" strokeWidth="2" />
          <circle cx="80" cy="78" r="8" fill="#F472B6" stroke="#FDF2F8" strokeWidth="2" />
          <circle cx="108" cy="78" r="8" fill="#F472B6" stroke="#FDF2F8" strokeWidth="2" />
          <rect x="44" y="18" width="66" height="22" rx="10" fill="#FDF2F8" stroke="#FBCFE8" strokeWidth="1.5" />
          <rect x="40" y="21" width="12" height="8" rx="4" fill="#FBCFE8" />
          <rect x="56" y="21" width="12" height="8" rx="4" fill="#FBCFE8" />
