            />
          </div>
        )}

        {stations.length > 0 && (
          <div className="space-y-2">
            <p className="text-xs text-rose-400 font-caveat text-center">
              Our journey so far...
            </p>
            <MemoryStrip stations={stations} />
          </div>
        )}
      </div>
    </motion.div>
  );
}
