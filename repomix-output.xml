      initial={{ scale: 0.8, opacity: 0 }}
      animate={{ scale: 1, opacity: 1 }}
      transition={{ type: "spring", stiffness: 200, damping: 12 }}
    >
      <motion.div
        key={value}
        className="bg-white/70 backdrop-blur-sm rounded-2xl px-4 py-3 md:px-5 md:py-4 min-w-[72px] md:min-w-[88px] glow-soft"
        initial={{ y: -12, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        transition={{ type: "spring", stiffness: 300, damping: 15 }}
      >
        <motion.span
          suppressHydrationWarning
          className="text-4xl md:text-5xl font-bold text-gradient-rose tracking-tight leading-none block text-center"
        >
          {String(value).padStart(2, "0")}
        </motion.span>
      </motion.div>
