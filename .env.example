# Google Apps Script web app URL (from Deploy → New Deployment)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Admin PIN for CRUD operations
ADMIN_PIN=2026

# ImgBB API key (free, sign up at imgbb.com)
# Already has a default dev key in code, swap with yours for production
NEXT_PUBLIC_IMGBB_KEY=your_key_here
